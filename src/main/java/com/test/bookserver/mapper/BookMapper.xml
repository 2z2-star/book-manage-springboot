<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.test.bookserver.mapper.BookMapper">
    <cache/>

    <select id="selectAll" resultType="Book">
        SELECT id,name,author,press,category,stock FROM book
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO book(name,author,press,category,stock)
        VALUES(#{name},#{author},#{press},#{category},#{stock})
    </insert>

    <update id="updateById">
        UPDATE book
        SET name=#{name}, author=#{author}, press=#{press}, category=#{category}, stock=#{stock}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM book WHERE id = #{id}
    </delete>

    <delete id="deleteAll">
        TRUNCATE TABLE book
    </delete>
    <select id="selectByLike" resultType="Book">
        SELECT id,name,author,press,category,stock FROM book
        <where>
            <if test="name != null and name != ''">
                name LIKE CONCAT('%',#{name},'%')
            </if>
            <if test="author != null and author != ''">
                AND author LIKE CONCAT('%',#{author},'%')
            </if>
        </where>
    </select>
</mapper>